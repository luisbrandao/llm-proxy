# Proxy auth keys for permission-gated backends (comma-separated for several).
# Clients send one as `Authorization: Bearer <key>`. Empty = gate disabled.
PROXY_API_KEYS=sk-proxy-change-me

# Provider (DeepSeek/OpenRouter) API keys live directly in config.yaml. They can
# optionally be pulled from the environment via ${VAR} interpolation in that file
# if you'd rather keep them here instead — e.g. uncomment and reference them:
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# OPENROUTER_API_KEY=sk-your-openrouter-key
